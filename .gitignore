# Secrets & env
.env
.env.*
!.env.example

# Node / TypeScript — dependencies & build output
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
*.log
npm-debug.log*

# Imported data may contain pupil data — keep it local
data/imports/*
!data/imports/README.md

# Local backups (DB dumps + resource-store snapshots)
backups/
*.dump
*.sql.gz

# Editor / OS / Agent metadata
.DS_Store
Thumbs.db
.idea/
.agents/
.claude/

# Hosted resource store (large; bind-mounted into the app)
data/resources/

# Teach Computing source lesson FILES (~4.8GB+, being uploaded) — too large to commit, and may include
# hand-edited / pupil-data-adjacent material. Keep LOCAL ONLY. NB: the importer (Phase 17) still reads this
# directory from disk — git-ignored ≠ off-limits to the app/agent. (The small curriculum-map xlsx in
# docs/TeachComputing_docs/ are separate and ARE tracked.)
/TeachComputing/

# Reconcile manifests — regenerable output from `npm run reconcile`; list paths from the
# pupil-data-sensitive old_lesson_plan folder, so keep them local.
data/reconcile-report/
instances/

# Redirected test output (scratch — never commit)
app/test_out.txt

# Playwright E2E (browser artifacts + saved auth state)
app/e2e/.auth/
app/test-results/
app/playwright-report/
app/blob-report/
docs/GradesMarksAndPercentageScores_Subject_821531_27_06_2026_14_38_37.csv
