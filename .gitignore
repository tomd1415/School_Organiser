# Secrets & env
.env
.env.*
!.env.example

# Node / TypeScript — dependencies & build output
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
*.log
npm-debug.log*

# Imported data may contain pupil data — keep it local
data/imports/*
!data/imports/README.md

# Local backups (DB dumps + resource-store snapshots)
backups/
*.dump
*.sql.gz

# Editor / OS / Agent metadata
.DS_Store
Thumbs.db
.idea/
.agents/
.claude/

# Hosted resource store (large; bind-mounted into the app)
data/resources/

# Reconcile manifests — regenerable output from `npm run reconcile`; list paths from the
# pupil-data-sensitive old_lesson_plan folder, so keep them local.
data/reconcile-report/
instances/

# Redirected test output (scratch — never commit)
app/test_out.txt
