# Copy to .env and fill in. .env is git-ignored (see repo-root .gitignore).
NODE_ENV=development
PORT=44360
HOST=0.0.0.0

# Dev DB: docker compose maps host 5434 -> container 5432
DATABASE_URL=postgres://organiser:organiser@localhost:5434/organiser

# 32-byte key as 64 hex chars. Generate:  openssl rand -hex 32
SESSION_KEY=replace_with_64_hex_chars

# Your login password, hashed. Generate:  npm run hash-password -- 'your-password'
APP_PASSWORD_HASH=replace_me

# Set true only when served over HTTPS (production behind Caddy)
COOKIE_SECURE=false
