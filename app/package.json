{
  "name": "school-organiser",
  "private": true,
  "version": "0.0.0",
  "description": "Single-teacher command centre — Phase 0 skeleton",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/seed/run.ts",
    "generate-recurring": "tsx src/jobs/generateRecurring.ts",
    "import-resources": "tsx src/jobs/importResources.ts",
    "reconcile": "tsx src/jobs/reconcileOldPlans.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "export-year": "tsx scripts/export-year.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/secure-session": "^8.1.0",
    "@fastify/static": "^9.1.3",
    "adm-zip": "^0.5.17",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
