# Production reverse proxy for the School Organiser on the school LAN.
# SITE_ADDRESS is injected from app/.env by the compose `caddy` service (deploy/install.sh sets it),
# e.g. organiser.school.internal — or a bare IP like 192.168.1.50.
#
# `tls internal` issues a self-signed certificate from Caddy's own CA, so HTTPS works on a LAN that
# has no public DNS and no internet-facing ACME. Accept it once in the browser, or install Caddy's
# root CA on the teacher's devices (see DEPLOYMENT.md). If SITE_ADDRESS is a REAL, internet-
# resolvable hostname and the box can reach Let's Encrypt, delete the `tls internal` line for a
# publicly-trusted cert instead.
{$SITE_ADDRESS} {
	encode gzip
	tls internal
	reverse_proxy app:44360 {
		# BUG-045: overwrite X-Forwarded-For with the REAL client address, discarding anything the client
		# sent — so the app's TRUST_PROXY reads a trustworthy client IP and the per-IP login/PIN rate
		# limits key on the actual device, not all-collapsed-to-Caddy and not a spoofable header.
		header_up X-Forwarded-For {http.request.remote.host}
	}
}

# ── Plain-HTTP only (no TLS) ────────────────────────────────────────────────
# To skip certificates entirely on a trusted LAN: comment out the block above, set
# COOKIE_SECURE=false in app/.env, and use this instead (then browse to http://SITE_ADDRESS/):
# :80 {
# 	encode gzip
# 	reverse_proxy app:44360 {
# 		header_up X-Forwarded-For {http.request.remote.host}
# 	}
# }
